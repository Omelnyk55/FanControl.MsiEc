{
  // Rename this file to FanControl.MsiEc.json (keep it next to the plugin dll)
  // if you need to change anything. Defaults shown below.

  // Opt-in for EC firmware families not in the built-in verified list.
  // Example: ["1552EMS1"]. Only add yours if you are confident your MSI
  // laptop uses the standard MSI EC register layout.
  "additionalFirmwarePrefixes": [],

  // GPU fan sensors/control: "auto" = detect at startup, "on", "off".
  "gpuFan": "auto",

  // Engage MSI Cooler Boost (instant max fan, bypasses the EC's slow ~1%/s
  // ramp) when a control is asked for at least this duty %. 1..100; 0 = off.
  "coolerBoostAtDuty": 100
}
